# Output directory for crawled files
W2L_OUTPUT_DIR=./data

# SQLite database path for URL queue
W2L_DB_PATH=./crawl.db

# Max BFS depth from seed URLs
W2L_MAX_DEPTH=3

# Max pages to save before stopping
W2L_MAX_PAGES=1000

# Concurrent requests per batch
W2L_CONCURRENCY=10

# HTTP timeout in seconds
W2L_TIMEOUT=30

# Number of seed URLs from search
W2L_SEARCH_MAX_RESULTS=20

# Follow links from crawled pages (true/false)
W2L_FOLLOW_LINKS=true

# Stay on the same domain only (true/false)
W2L_SAME_DOMAIN_ONLY=false
